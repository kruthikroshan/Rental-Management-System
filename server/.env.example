# SmartRent Server Configuration
# Copy this file to .env and fill in your actual values

NODE_ENV=development
PORT=4000

# Database Configuration
# MongoDB for Users & Auth
MONGO_URI=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/?appName=YourAppName

# PostgreSQL for Products & Rentals (optional)
# POSTGRES_URL=postgresql://postgres:password@localhost:5432/smartrent_products

# JWT Configuration (use strong random secrets in production)
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# Cookie Configuration
COOKIE_NAME=sr_refresh_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_PATH=/

# Email Configuration (for OTP verification)
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password_here

# CORS Configuration
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174

# Admin Setup (for seed script)
ADMIN_EMAIL=admin@smartrent.com
ADMIN_PASSWORD=your_admin_password
ADMIN_NAME=SmartRent Admin

# Razorpay Payment Gateway (get credentials from razorpay.com)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Google OAuth Configuration
# Create OAuth credentials at: https://console.cloud.google.com/
# Set authorized redirect URI to: http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
